{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://ILI-BACKEND-RENDER-URL.onrender.com/api/:path*"
    },
    {
      "source": "/ws/:path*",
      "destination": "https://ILI-BACKEND-RENDER-URL.onrender.com/ws/:path*"
    },
    {
      "source": "/",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ]
}
